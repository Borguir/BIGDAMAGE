extends Node2D


var escena_player = preload("res://Personajes/player_1.tscn")
var player = escena_player.instantiate()
var escena_enemigo = preload("res://Personajes/enemigo_1.tscn")
var enemigo = escena_enemigo.instantiate()

#region Onreadys
@onready var StatsPlayer = preload("res://Recursos/Stats_Player.tres")


@onready var botones = [$Acciones/VBoxContainer/Atacar, $Acciones/VBoxContainer/Cargar, $Acciones/VBoxContainer/Habilidad]
@onready var resaltar = $Resaltador
@onready var tilemap = $TileMapLayer
@onready var boton_atacar = $Acciones/VBoxContainer/Atacar
@onready var boton_cargar = $Acciones/VBoxContainer/Cargar
@onready var boton_habilidad = $Acciones/VBoxContainer/Habilidad
#endregion

enum Estado {
	ELEGIR_POSICION,
	ELEGIR_OBJETIVO,
	ELEGIR_ACCION,
	RESOLVER,
	OBJETIVO_ENEMIGO,
	RESOLVER_ENEMIGO
}

var estado_actual = Estado.ELEGIR_POSICION
var posicion_player: Vector2i
var objetivo_elegido: Vector2i

#Ordenar Despues
var tiles_enemigo = [
	Vector2i(5, 0), Vector2i(5, 1), Vector2i(5, 2),
	Vector2i(6, 0), Vector2i(6, 1), Vector2i(6, 2)
]
var indice_objetivo = 0


func _ready() -> void:
	add_child(player)
	add_child(enemigo)
	player.posicion_cambiada.connect(_on_player_posicion_cambiada)
	cambiar_estado(Estado.ELEGIR_POSICION)
	desabilitar_botones()

func cambiar_estado(nuevo_estado) -> void:
	estado_actual = nuevo_estado
	match estado_actual:
		Estado.ELEGIR_POSICION:
			desabilitar_botones()
			resaltar.clear()
			resaltar_player()
			print("elegí posición")
		Estado.ELEGIR_OBJETIVO:
			desabilitar_botones()
			indice_objetivo = 0
			resaltar_objetivo()
			print("elegí objetivo")
		Estado.ELEGIR_ACCION:
			habilitar_botones()
			botones[0].grab_focus()
			print("posición confirmada en ", posicion_player)
			print("ahora elegí acción")
		Estado.RESOLVER:
			desabilitar_botones()
			print("resolviendo")
		Estado.OBJETIVO_ENEMIGO:
			print("OBjetivo del enemigo")
		Estado.RESOLVER_ENEMIGO:
			print("Enemigo ataca")

func _input(_event: InputEvent) -> void:
	if Input.is_action_just_pressed("ui_accept"):
		if estado_actual == Estado.ELEGIR_POSICION:
			posicion_player = player.grid_pos
			cambiar_estado(Estado.ELEGIR_OBJETIVO)
			get_viewport().set_input_as_handled()
			
		elif estado_actual == Estado.ELEGIR_OBJETIVO:
			objetivo_elegido = tiles_enemigo[indice_objetivo]
			cambiar_estado(Estado.ELEGIR_ACCION)
			get_viewport().set_input_as_handled()
	
	if estado_actual == Estado.ELEGIR_OBJETIVO:
		if Input.is_action_just_pressed("ui_down") or Input.is_action_just_pressed("ui_right"):
			indice_objetivo = (indice_objetivo + 1) % tiles_enemigo.size()
			resaltar_objetivo()
		elif Input.is_action_just_pressed("ui_up") or Input.is_action_just_pressed("ui_left"):
			indice_objetivo = (indice_objetivo - 1 + tiles_enemigo.size()) % tiles_enemigo.size()
			resaltar_objetivo()

func habilitar_botones():
	boton_atacar.disabled = false
	boton_cargar.disabled = false
	boton_habilidad.disabled = false
	for boton in botones:
		boton.focus_mode = Control.FOCUS_ALL

func desabilitar_botones():
	boton_atacar.disabled = true
	boton_cargar.disabled = true
	boton_habilidad.disabled = true
	for boton in botones:
		boton.focus_mode = Control.FOCUS_NONE

#region Resaltados
func resaltar_objetivo():
	actualizar_resaltado_visual()

func _on_player_posicion_cambiada(_nueva_pos):
	actualizar_resaltado_visual()

func actualizar_resaltado_visual():
	resaltar.clear()
	match estado_actual:
		Estado.ELEGIR_POSICION:
			resaltar.set_cell(player.grid_pos, 0, Vector2i(0, 0))
		Estado.ELEGIR_OBJETIVO:
			resaltar.set_cell(posicion_player, 0, Vector2i(0, 0))
			resaltar.set_cell(tiles_enemigo[indice_objetivo], 1, Vector2i(0, 0))

func resaltar_player():
	actualizar_resaltado_visual()
#endregion

func animar_golpe_player():
	if estado_actual != Estado.RESOLVER:
		return
	else:
		var destino = tilemap.map_to_local(objetivo_elegido)
		var origen = tilemap.map_to_local(posicion_player)
		var tween = create_tween()
		tween.tween_property(player, "position", destino, 0.3)
		tween.tween_property(player, "position", origen, 0.3)
		tween.tween_callback(func(): cambiar_estado(Estado.OBJETIVO_ENEMIGO))

func do_damage():
	pass

func _on_atacar_pressed() -> void:
	cambiar_estado(Estado.RESOLVER)
	animar_golpe_player()
