#Player

extends Area2D



var grid_min = Vector2i(3, 0)
var grid_max = Vector2i(4, 2)
@onready var battle_manager = $".."
@onready var tilemap: TileMapLayer = $"../TileMapLayer"
var grid_pos: Vector2i = Vector2i(3, 1)
var moviéndose: bool = false

func _ready() -> void:
	position = tilemap.map_to_local(grid_pos)

func _input(_event: InputEvent) -> void:
	if battle_manager.estado_actual != battle_manager.Estado.ELEGIR_POSICION:
		return
	
	if Input.is_action_just_pressed("ui_right"):
		intentar_mover(Vector2i(1, 0))
	elif Input.is_action_just_pressed("ui_left"):
		intentar_mover(Vector2i(-1, 0))
	elif Input.is_action_just_pressed("ui_up"):
		intentar_mover(Vector2i(0, -1))
	elif Input.is_action_just_pressed("ui_down"):
		intentar_mover(Vector2i(0, 1))

func intentar_mover(direccion: Vector2i):
	if moviéndose:
		return
	var nueva_pos = grid_pos + direccion
	if es_celda_valida(nueva_pos):
		grid_pos = nueva_pos
		mover_a_celda(grid_pos)

func es_celda_valida(pos: Vector2i) -> bool:
	if pos.x < grid_min.x or pos.x > grid_max.x:
		return false
	if pos.y < grid_min.y or pos.y > grid_max.y:
		return false
	var tile_data = tilemap.get_cell_tile_data(pos)
	if tile_data == null:
		return false
	return true

func mover_a_celda(pos: Vector2i):
	var destino = tilemap.map_to_local(pos)
	moviéndose = true
	var tween = create_tween()
	tween.tween_property(self, "position", destino, 0.1)
	tween.tween_callback(func(): moviéndose = false)
