extends Node2D


@onready var cara = $Icon

enum Estado {
	A,
	B,
	C
}

var estado_actual = Estado.A

func _process(delta: float) -> void:
	hacer_algo()

func cambiar_estado(nuevo_estado) -> void:
	estado_actual = nuevo_estado
	match estado_actual:
		Estado.A:
			print("entramos a A, hacemos setup de A")

		Estado.B:
			print("entramos a B, hacemos setup de B")

		Estado.C:
			print("entramos a C, hacemos setup de C")




func hacer_algo():
	if Input.is_action_just_pressed("ui_accept"):
		cambiar_estado(Estado.A)
